# Azure Bing Web Search API key
# Create a Bing Search resource in Azure Portal:
#   https://portal.azure.com/#create/Microsoft.BingSearch
# Then copy the key from Keys and Endpoint blade.
BING_SEARCH_API_KEY=your-bing-search-api-key-here

# ──────────────────────────────────────────────────
# Social Media Publishing — MCP Server Credentials
# See docs/social-api-setup.md for step-by-step guide
# ──────────────────────────────────────────────────

# Reddit (free) — reddit-mcp-server
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# LinkedIn (free tier) — mcp-linkedin via Unipile
# Sign up at https://www.unipile.com, connect LinkedIn, copy API key + DSN
UNIPILE_API_KEY=your-unipile-api-key
UNIPILE_DSN=apiXX.unipile.com:XXXXX

# X/Twitter (free tier: 1,500 tweets/month) — custom MCP server
# Create a project at https://developer.x.com/en/portal/dashboard
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# YouTube Data API v3 (free: 10K quota units/day) — custom MCP server
# Enable YouTube Data API v3 at https://console.cloud.google.com
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# ──────────────────────────────────────────────────
# AI Image Generation (hybrid visual family: hero/illustrative only)
# See agents-and-skills/image-provider-comparison.md to choose a provider.
# ──────────────────────────────────────────────────

# Provider selector: openai | azure_openai
IMAGE_PROVIDER=openai

# Model + defaults (used for both generation and vision grounding)
IMAGE_MODEL_NAME=gpt-image-1
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=medium
# Vision model used to describe reference images for grounding
VISION_MODEL_NAME=gpt-4o

# --- OpenAI (when IMAGE_PROVIDER=openai) ---
OPENAI_API_KEY=your-openai-api-key

# --- Azure OpenAI (when IMAGE_PROVIDER=azure_openai) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_IMAGE_API_VERSION=2025-04-01-preview
